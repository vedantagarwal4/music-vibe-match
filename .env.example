# Copy this file to .env and fill in all values.
# .env is gitignored - never commit it.

# -------------------------------------------------------
# SHAZAM
# Your session cookies from shazam.com (see SETUP.md Step 1)
# -------------------------------------------------------
SHAZAM_COOKIES=

# -------------------------------------------------------
# YOUTUBE MUSIC
# Browser headers JSON string (see SETUP.md Step 2)
# -------------------------------------------------------
YTMUSIC_HEADERS=

# The YouTube Music playlist to check for duplicates.
# How to find playlist ID: open the playlist on music.youtube.com,
# the ID is in the URL after "list=" e.g. PLxxxxxxxxxxxxxx
CHECK_PLAYLIST_ID=

# The YouTube Music playlist used for your taste profile
# (can be the same as CHECK_PLAYLIST_ID or different)
TASTE_PLAYLIST_ID=

# -------------------------------------------------------
# GEMINI AI
# Free API key from https://aistudio.google.com/app/apikey
# -------------------------------------------------------
GEMINI_API_KEY=

# -------------------------------------------------------
# GMAIL
# Your Gmail address
# App Password (NOT your normal password) from:
# https://myaccount.google.com/apppasswords
# -------------------------------------------------------
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Optional: different address to send the digest TO
# (defaults to GMAIL_ADDRESS if not set)
TO_EMAIL=

# -------------------------------------------------------
# SCORING
# Songs with score >= this are included in the email
# Default: 6  (try 7 for stricter filtering)
# -------------------------------------------------------
SCORE_THRESHOLD=6
